{
  "name": "blurrysite",
  "version": "1.0.0",
  "description": "Browser extension to blur text, images, and videos for privacy",
  "license": "GPL-3.0-or-later",
  "author": "Chennakeshava G <gudapallichennakeshava@gmail.com>",
  "homepage": "https://github.com/ChennakeshavaG/blurrysite",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChennakeshavaG/blurrysite.git"
  },
  "bugs": {
    "url": "https://github.com/ChennakeshavaG/blurrysite/issues"
  },
  "scripts": {
    "test": "npm run i18n:lint && npm run string:lint && jest --coverage",
    "test:unit": "npm run i18n:lint && npm run string:lint && jest tests/unit",
    "test:e2e": "jest tests/e2e --testTimeout=30000",
    "test:watch": "jest --watch",
    "lint": "eslint src/ popup/ tests/ background.js build.js scripts/",
    "i18n:lint": "node scripts/i18n_lint.js",
    "string:lint": "node scripts/string_lint.js",
    "build": "node build.js",
    "release": "npm run test:unit && npm run build",
    "test:perf:playwright": "cd tests/perf/playwright && npm install --prefer-offline 2>/dev/null; npm test",
    "test:perf:fixture": "cd tests/perf/playwright && node run-fixture.js",
    "test:perf:fixture:headless": "cd tests/perf/playwright && node run-fixture.js --headless",
    "test:perf:all-fixtures": "cd tests/perf/playwright && node run-all-fixtures.js",
    "test:perf:all-fixtures:headless": "cd tests/perf/playwright && node run-all-fixtures.js --headless",
    "test:perf:analysis": "cd tests/perf/playwright && node generate-analysis.js"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "puppeteer": "^23.11.1",
    "puppeteer-core": "^23.11.1"
  },
  "dependencies": {
    "text-security": "^3.2.1"
  }
}
